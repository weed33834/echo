# Echo 环境变量示例
# 复制此文件为 .env 并填入你的配置

# AI 对话 API Key（也可在应用内"设置"页面配置）
VITE_DEEPSEEK_API_KEY=
VITE_OPENAI_API_KEY=
VITE_CLAUDE_API_KEY=

# Tavily 搜索 API Key（AI 联网搜索功能，可选）
VITE_TAVILY_API_KEY=

# 默认 AI 模型配置（可选，留空则使用应用内设置）
VITE_DEFAULT_BASE_URL=https://api.deepseek.com/v1
VITE_DEFAULT_MODEL=deepseek-chat
